# ============================================
# IISH Fashion - Environment Configuration
# Copy this file to .env and update values
# ============================================

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=iish_fashion
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Admin Configuration
ADMIN_EMAIL=admin@iishfashion.com
ADMIN_PASSWORD=Admin@123

# Paystack Configuration (Nigerian Payment Gateway)
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
PAYSTACK_BASE_URL=https://api.paystack.co

# Flutterwave Configuration (Alternative Payment)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLUTTERWAVE_PUBLIC_KEY=FLWPUB_TEST-your_public_key
FLUTTERWAVE_ENCRYPTION_KEY=your_encryption_key

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=IISH Fashion <noreply@iishfashion.com>

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Security Configuration
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Shipping Configuration
DEFAULT_SHIPPING_COST=2500
FREE_SHIPPING_THRESHOLD=50000
SHIPPING_PROVIDER=local

# Currency Configuration
CURRENCY=NGN
CURRENCY_SYMBOL=₦
